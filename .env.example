# Porta em que o llm-chat vai rodar
PORT=4000

# URL do servidor LLM local (API compatível com OpenAI)
# LM Studio:  http://localhost:1234
# Ollama:     http://localhost:11434
# llama.cpp:  http://localhost:8080
LLM_URL=http://localhost:1234

# URL do ComfyUI para geração de imagens (opcional)
# Se não definido, o comando /img fica desabilitado
COMFY_URL=http://192.168.100.57:8188

# Nomes dos arquivos de modelo no ComfyUI (ajuste se os seus tiverem nomes diferentes)
COMFY_UNET=flux1-dev-fp8.safetensors
COMFY_CLIP1=t5xxl_fp8_e4m3fn.safetensors
COMFY_CLIP2=clip_l.safetensors
COMFY_VAE=ae.safetensors
